{
  "manifest_version": 3,
  "name": "ClipVault: Neural Snatcher",
  "version": "1.0",
  "description": "Inject text and images directly into your ClipVault from anywhere on the web.",
  "permissions": ["contextMenus", "storage", "notifications"],
  "host_permissions": ["*://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
